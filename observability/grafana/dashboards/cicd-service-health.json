    {
      "id": 9,
      "type": "table",
      "title": "Jobs — Last Build Result (비정상만)",
      "description": "ordinal: 0 SUCCESS / 1 UNSTABLE / 2 FAILURE / 3 NOT_BUILT / 4 ABORTED. >=1 만 표시.",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "default_jenkins_builds_last_build_result_ordinal >= 1",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "Value": "result",
              "jenkins_job": "job"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "result",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "result"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "UNSTABLE",
                        "color": "yellow",
                        "index": 0
                      },
                      "2": {
                        "text": "FAILURE",
                        "color": "red",
                        "index": 1
                      },
                      "3": {
                        "text": "NOT_BUILT",
                        "color": "gray",
                        "index": 2
                      },
                      "4": {
                        "text": "ABORTED",
                        "color": "orange",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
