#!/bin/bash
#
# post-commit — trunk 커밋 시 MailHog로 알림 (방향 A: 알림 전용, 빌드 트리거 안 함)
#
# 인자 (Subversion이 전달):
#   $1 = REPOS  저장소 경로
#   $2 = REV    방금 "확정된" 리비전 번호 (트랜잭션이 아니라 실제 리비전)
#
# 설계 원칙 (post-commit은 pre-commit과 정반대):
#   - 이미 끝난 커밋의 후처리다. 여기서 실패해도 커밋은 되돌릴 수 없다.
#     → 어떤 경우에도 커밋을 실패시키지 않는다. 항상 exit 0.
#   - 알림 전송은 백그라운드로 던져 `svn commit` 명령이 멈추지 않게 한다.
#   - 백그라운드라 화면에 아무것도 안 보이므로, 성공/실패를 반드시 로그로 남긴다.
#
# self-discovery:
#   저장소 디렉토리명(basename "$REPOS")이 곧 앱 이름이므로 앱/팀을 스스로 판별한다.
#   → 저장소마다 다른 훅 파일을 둘 필요가 없다. 이 파일 1벌을 각 repo에 복사만 하면 된다.

export PATH=/usr/local/bin:/usr/bin:/bin
export LANG=C.UTF-8
export LC_ALL=C.UTF-8

REPOS="$1"
REV="$2"
SVNLOOK=/usr/bin/svnlook

# ───────── 로그 ─────────
# 훅은 apache(www-data)가 commit을 처리할 때 실행되므로, 이 디렉토리는
# www-data가 쓸 수 있어야 한다 (init-svn.sh에서 미리 생성/소유권 부여).
# 로그를 못 써도 훅 자체가 깨지면 안 되므로 모든 실패를 무시한다.
HOOK_LOG_DIR="${HOOK_LOG_DIR:-/var/log/svn-hooks}"
HOOK_NAME="$(basename "$0")"

log_hook() {
    printf '%s [%s] [%s] %s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$HOOK_NAME" \
        "$(basename "$REPOS")" \
        "$*" >> "${HOOK_LOG_DIR}/${HOOK_NAME}.log" 2>/dev/null || true
}

# ───────── 설정 (환경변수로 덮어쓸 수 있고, 없으면 기본값) ─────────
# SVN 훅은 빈 환경에서 실행되므로, 기본값을 박아두어 환경변수 주입 없이도 동작하게 한다.
SMTP_HOST="${SMTP_HOST:-mailhog}"
SMTP_PORT="${SMTP_PORT:-1025}"
MAIL_FROM="${MAIL_FROM:-admin@example.com}"
TRUNK_ONLY="${TRUNK_ONLY:-1}"     # 1이면 trunk 변경이 있을 때만 알림 (tags/branches 무시)

# ───────── 앱 → 팀 알림 메일 매핑 ─────────
# (Rundeck/seed 의 팀 표기와 맞춤: payment-team / web-team / ml-team)
APP="$(basename "$REPOS")"
case "$APP" in
    sample-spring)  TEAM_EMAIL="payment-team@example.com" ;;
    sample-react)   TEAM_EMAIL="web-team@example.com"     ;;
    sample-fastapi) TEAM_EMAIL="ml-team@example.com"      ;;
    *)              TEAM_EMAIL="dev@example.com"           ;;   # shared-library 등
esac

# ───────── SMTP 전송 (curl) ─────────
# 가독성을 위해 curl 사용. svn 이미지에 curl이 포함되어 있어야 한다.
send_mail() {
    local to="$1" subject="$2" body="$3"

    local mail_file
    mail_file="$(mktemp)"
    {
        printf 'From: %s\r\n' "$MAIL_FROM"
        printf 'To: %s\r\n' "$to"
        printf 'Subject: %s\r\n' "$subject"
        printf 'MIME-Version: 1.0\r\n'
        printf 'Content-Type: text/plain; charset=UTF-8\r\n'
        printf '\r\n'
        printf '%s\r\n' "$body"
    } > "$mail_file"

    curl -s --max-time 10 \
        --url "smtp://${SMTP_HOST}:${SMTP_PORT}" \
        --mail-from "$MAIL_FROM" \
        --mail-rcpt "$to" \
        --upload-file "$mail_file"
    local rc=$?

    rm -f "$mail_file"
    return $rc
}

notify() {
    local author date logmsg changed subject body

    author="$("$SVNLOOK" author  -r "$REV" "$REPOS" 2>/dev/null)"
    date="$(  "$SVNLOOK" date    -r "$REV" "$REPOS" 2>/dev/null)"
    logmsg="$("$SVNLOOK" log     -r "$REV" "$REPOS" 2>/dev/null)"
    changed="$("$SVNLOOK" changed -r "$REV" "$REPOS" 2>/dev/null)"

    # trunk 변경이 없으면 알림 생략 (TRUNK_ONLY=1)
    if [ "$TRUNK_ONLY" = "1" ]; then
        if ! printf '%s\n' "$changed" | cut -c5- | grep -q '^trunk/'; then
            log_hook "SKIP: r${REV} (trunk 변경 없음)"
            return 0
        fi
    fi

    subject="[SVN][${APP}] r${REV} committed by ${author}"
    body="$(cat <<EOF
SVN 커밋 알림

애플리케이션 : ${APP}
리비전       : r${REV}
작성자       : ${author}
일시         : ${date}

커밋 메시지
------------------------------
${logmsg}

변경 파일
------------------------------
${changed}
EOF
)"

    log_hook "NOTIFY: r${REV} author=${author} → ${TEAM_EMAIL}"
    if send_mail "$TEAM_EMAIL" "$subject" "$body"; then
        log_hook "MAIL OK: r${REV} → ${TEAM_EMAIL}"
    else
        log_hook "MAIL FAILED: r${REV} → ${TEAM_EMAIL} (curl rc=$?)"
    fi
}

# 어떤 실패도 커밋에 영향 주지 않도록: 백그라운드로 던지고 에러는 무시한다.
( notify ) >/dev/null 2>&1 &

exit 0
