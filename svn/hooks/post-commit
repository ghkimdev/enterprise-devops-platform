#!/bin/bash
#
# post-commit — trunk 커밋 시 MailHog로 알림 (방향 A: 알림 전용, 빌드 트리거 안 함)
#
# 인자 (Subversion이 전달):
#   $1 = REPOS  저장소 경로
#   $2 = REV    방금 "확정된" 리비전 번호
#
# 설계 원칙:
#   - 이미 끝난 커밋의 후처리다. 여기서 실패해도 커밋은 되돌릴 수 없다 → 항상 exit 0.
#   - 알림 전송은 백그라운드로 던져 `svn commit` 이 멈추지 않게 한다.
#   - 백그라운드라 화면에 안 보이므로, 각 단계의 START/OK 를 로그로 남긴다.
#     로그에서 마지막 START(혹은 FAILED) 가 곧 실패 지점이 된다.
#
# self-discovery:
#   저장소 디렉토리명(basename "$REPOS")이 곧 앱 이름이므로 앱/팀을 스스로 판별한다.

export PATH=/usr/local/bin:/usr/bin:/bin
export LANG=C.UTF-8
export LC_ALL=C.UTF-8

REPOS="$1"
REV="$2"
SVNLOOK=/usr/bin/svnlook

# ───────── 로그 ─────────
HOOK_LOG_DIR="${HOOK_LOG_DIR:-/var/log/svn-hooks}"
HOOK_NAME="$(basename "$0")"
RUN_ID="$$"                 # 동시 커밋 구분용 상관 ID
CURRENT_STAGE="-"

log_hook() {
    printf '%s [%s] [%s] [#%s] %s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$HOOK_NAME" \
        "$(basename "$REPOS")" \
        "$RUN_ID" \
        "$*" >> "${HOOK_LOG_DIR}/${HOOK_NAME}.log" 2>/dev/null || true
}

# 단계 래퍼: START 찍고 → 함수 실행 → 반환값에 따라 OK/FAILED.
# post-commit은 절대 죽으면 안 되므로 실패해도 exit 하지 않고 로그만 남긴다.
run_stage() {
    CURRENT_STAGE="$1"; shift
    log_hook "START: ${CURRENT_STAGE}"
    if "$@"; then
        log_hook "OK: ${CURRENT_STAGE}"
        return 0
    else
        log_hook "FAILED [${CURRENT_STAGE}]: rc=$?"
        return 1
    fi
}

# ───────── 설정 ─────────
SMTP_HOST="${SMTP_HOST:-mailhog}"
SMTP_PORT="${SMTP_PORT:-1025}"
MAIL_FROM="${MAIL_FROM:-admin@example.com}"
TRUNK_ONLY="${TRUNK_ONLY:-1}"

# ───────── 앱 → 팀 알림 메일 매핑 ─────────
APP="$(basename "$REPOS")"
case "$APP" in
    sample-spring)  TEAM_EMAIL="payment-team@example.com" ;;
    sample-react)   TEAM_EMAIL="web-team@example.com"     ;;
    sample-fastapi) TEAM_EMAIL="ml-team@example.com"      ;;
    *)              TEAM_EMAIL="dev@example.com"           ;;
esac

# 단계 간 공유 변수
AUTHOR=""; CDATE=""; LOGMSG=""; CHANGED=""; SUBJECT=""; BODY=""

# ───────── SMTP 전송 (curl) ─────────
send_mail() {
    local to="$1" subject="$2" body="$3" rc
    local mail_file
    mail_file="$(mktemp)"
    {
        printf 'From: %s\r\n' "$MAIL_FROM"
        printf 'To: %s\r\n' "$to"
        printf 'Subject: %s\r\n' "$subject"
        printf 'MIME-Version: 1.0\r\n'
        printf 'Content-Type: text/plain; charset=UTF-8\r\n'
        printf '\r\n'
        printf '%s\r\n' "$body"
    } > "$mail_file"

    curl -s --max-time 10 \
        --url "smtp://${SMTP_HOST}:${SMTP_PORT}" \
        --mail-from "$MAIL_FROM" \
        --mail-rcpt "$to" \
        --upload-file "$mail_file"
    rc=$?
    rm -f "$mail_file"
    return $rc
}

# ============================================================
# 단계 함수들
# ============================================================

# 1) 메타데이터 수집
stage_collect() {
    AUTHOR="$("$SVNLOOK" author  -r "$REV" "$REPOS" 2>/dev/null)"
    CDATE="$( "$SVNLOOK" date    -r "$REV" "$REPOS" 2>/dev/null)"
    LOGMSG="$("$SVNLOOK" log     -r "$REV" "$REPOS" 2>/dev/null)"
    CHANGED="$("$SVNLOOK" changed -r "$REV" "$REPOS" 2>/dev/null)"
    return 0
}

# 2) trunk 필터 — trunk 변경이 없으면 1을 반환해 알림을 건너뛴다
stage_trunk_filter() {
    [ "$TRUNK_ONLY" = "1" ] || return 0
    if printf '%s\n' "$CHANGED" | cut -c5- | grep -q '^trunk/'; then
        return 0
    fi
    return 1   # trunk 변경 없음
}

# 3) 메일 본문 구성
stage_compose() {
    SUBJECT="[SVN][${APP}] r${REV} committed by ${AUTHOR}"
    BODY="$(cat <<EOF
SVN 커밋 알림

애플리케이션 : ${APP}
리비전       : r${REV}
작성자       : ${AUTHOR}
일시         : ${CDATE}

커밋 메시지
------------------------------
${LOGMSG}

변경 파일
------------------------------
${CHANGED}
EOF
)"
    return 0
}

# 4) 전송
stage_send() {
    send_mail "$TEAM_EMAIL" "$SUBJECT" "$BODY"
}

# ============================================================
# 실행 (백그라운드)
# ============================================================
main() {
    log_hook "BEGIN: rev=${REV} app=${APP} → ${TEAM_EMAIL}"

    run_stage "collect-metadata" stage_collect

    # trunk 변경이 없으면 정상 종료(알림 생략)
    CURRENT_STAGE="trunk-filter"
    log_hook "START: trunk-filter"
    if ! stage_trunk_filter; then
        log_hook "SKIP: trunk 변경 없음 → 알림 생략"
        log_hook "END: r${REV} (skipped)"
        return 0
    fi
    log_hook "OK: trunk-filter"

    run_stage "compose-mail" stage_compose
    run_stage "send-mail"    stage_send

    log_hook "END: r${REV} done"
}

# 어떤 실패도 커밋에 영향 주지 않도록: 백그라운드로 던지고 에러는 무시한다.
( main ) >/dev/null 2>&1 &

exit 0
