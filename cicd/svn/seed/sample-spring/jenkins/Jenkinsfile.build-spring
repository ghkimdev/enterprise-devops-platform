@Library('cicd-shared@trunk') _

buildPipeline([
    stack             : 'spring',
    appName           : 'sample-spring',
    agentImage        : 'jenkins-agent-java21:1.0.0',

    svnTrunk          : 'http://svn/svn/sample-spring/trunk',
    svnTags           : 'http://svn/svn/sample-spring/tags',
    svnCreds          : 'svn-creds',

    nexusBase         : 'http://nexus:8081',
    nexusCreds        : 'nexus-creds',
    mavenReleasesRepo : 'maven-releases',
    mavenGroupId      : 'dev.ghlab',
    mavenArtifactId   : 'sample-spring',

    dockerRegistry    : 'nexus.ghlab.dev:5000',
    dockerImage       : 'nexus.ghlab.dev:5000/sample-spring',

    checkitemJob      : 'payment/01.sample-spring-checkitem',
    devDeployJob      : 'payment/03.sample-spring-deploy',
    autoDeployEnv     : 'dev'
])
